{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "throttlingMethod": "simulate",
        "skipAudits": [
          "uses-http2",
          "is-crawlable",
          "csp-xss",
          "lcp-lazy-loaded"
        ]
      }
    },
    "assert": {
      "assertions": {
        "color-contrast": "error",
        "image-alt": "error",
        "html-has-lang": "error",
        "meta-description": "error",
        "document-title": "error",
        "cumulative-layout-shift": ["error", { "maxNumericValue": 0.1 }],

        "categories:accessibility": ["warn", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.95 }],
        "categories:performance": ["warn", { "minScore": 0.75 }],
        "categories:seo": ["warn", { "minScore": 0.90 }],

        "heading-order": "warn",
        "uses-responsive-images": "warn",
        "modern-image-formats": "warn",
        "render-blocking-resources": "warn",
        "first-contentful-paint": ["warn", { "maxNumericValue": 4000 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 5000 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 500 }],

        "resource-summary:script:size": ["warn", { "maxNumericValue": 600000 }],
        "resource-summary:stylesheet:size": ["warn", { "maxNumericValue": 50000 }],
        "resource-summary:image:size": ["warn", { "maxNumericValue": 300000 }],
        "resource-summary:total:count": ["warn", { "maxNumericValue": 30 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
